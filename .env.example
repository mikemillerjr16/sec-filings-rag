# Copy to .env and fill in. NEVER commit .env (it is gitignored).
# On AWS these come from SSM Parameter Store (Track 1) / Secrets Manager (Track 2).

# --- LLM / embeddings (OpenAI) ---
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# --- Reranking (Cohere on Track 1; local cross-encoder used only for local/Track 2) ---
COHERE_API_KEY=
RERANK_BACKEND=cohere            # cohere | local | none

# --- Observability (Langfuse Cloud free tier for hosted demo; self-hosted locally) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Vector store backend ---
STORE_BACKEND=lancedb            # lancedb | pgvector
# LanceDB (Track 1 / local): local path for dev, s3://... in Lambda
LANCEDB_URI=./data.nosync/lancedb
# pgvector (Track 2 / local docker): standard libpq DSN
PGVECTOR_DSN=postgresql://rag:rag@localhost:5432/rag

# --- SEC EDGAR (fair-use requires a descriptive User-Agent with contact info) ---
SEC_USER_AGENT=enterprise-rag-portfolio Mike Miller mike.millerjr16@gmail.com

# --- Track 1 endpoint auth (shared secret the Streamlit UI sends to the Lambda) ---
API_SHARED_SECRET=change-me-in-parameter-store

# --- Local data locations (kept out of iCloud via .nosync) ---
FILINGS_DIR=./filings.nosync
